# =============================================================
# Agow Automation - OpenClaw Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env to git
# =============================================================

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- WordPress REST API ---
# Application Password (generate in WP Admin > Users > Application Passwords)
WP_BASE_URL=https://agowautomation.com
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx-xxxx-xxxx

# --- WooCommerce REST API ---
# IMPORTANT: Separate from WP credentials!
# Generate in WP Admin > WooCommerce > Settings > Advanced > REST API
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Telegram Bot ---
# Create bot via @BotFather, then disable Privacy Mode (BotFather > /setprivacy > Disable)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Group chat ID (negative number, e.g. -1001234567890)
# Get it: add bot to group, send a message, then call https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_GROUP_CHAT_ID=-1001234567890

# Admin user ID (your personal Telegram user ID — full control, all tiers)
# Get it: message @userinfobot on Telegram
TELEGRAM_ADMIN_USER_ID=1234567890

# Operator user IDs (comma-separated — staff who can use Tier 1 + 2 but cannot approve Tier 3)
# Leave empty if only admin should use the bot
TELEGRAM_OPERATOR_USER_IDS=1111111111,2222222222

# --- Google Search Console ---
# Service account JSON key file path (inside container)
GSC_CREDENTIALS_PATH=/home/openclaw/secrets/gsc-service-account.json
GSC_SITE_URL=sc-domain:agowautomation.com

# --- OpenClaw Settings ---
OPENCLAW_SESSION_TIMEOUT=90
OPENCLAW_MAX_SESSIONS=5
OPENCLAW_LOG_LEVEL=info

# --- Model Configuration ---
# Primary model for complex tasks
PRIMARY_MODEL=claude-sonnet-4-6
# Secondary model for routine/monitoring tasks
SECONDARY_MODEL=claude-haiku-4-5
# Fallback model
FALLBACK_MODEL=gpt-4.1

# --- Rate Limits ---
MAX_API_CALLS_PER_HOUR=100
MAX_WP_WRITES_PER_HOUR=30
MAX_TELEGRAM_MESSAGES_PER_MINUTE=10

# --- Backup ---
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_DIR=/home/openclaw/backups
