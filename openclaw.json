{
  "$schema": "https://openclaw.ai/schema/config.json",
  "version": "1.1",
  "project": {
    "name": "Agow Automation",
    "description": "Multi-agent AI system for B&R Automation distributor in Vietnam",
    "language": "vi",
    "timezone": "Asia/Ho_Chi_Minh"
  },

  "models": {
    "providers": {
      "claudible": {
        "baseUrl": "https://claudible.io/v1",
        "apiKey": "${CLAUDIBLE_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "claude-sonnet-4.6",
            "name": "Claude Sonnet 4.6",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "claude-haiku-4.5",
            "name": "Claude Haiku 4.5",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "claude-opus-4.6",
            "name": "Claude Opus 4.6",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 16384
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": { "primary": "claudible/claude-sonnet-4.6" },
      "compaction": { "mode": "safeguard" },
      "maxConcurrent": 3
    },
    "list": [
      {
        "id": "lead",
        "default": true,
        "name": "Tong — Lead Agent",
        "workspace": "workspaces/lead",
        "description": "Smart router for ambiguous requests, monitor, capability evolution coordinator",
        "identity": { "name": "Tong", "emoji": "🧠" },
        "groupChat": {
          "mentionPatterns": ["@tong", "@lead"]
        },
        "maxConcurrentSessions": 3,
        "sessionTimeout": 90
      },
      {
        "id": "seo",
        "name": "Khoa — SEO Agent",
        "workspace": "workspaces/seo",
        "model": { "primary": "${SECONDARY_MODEL}" },
        "description": "SEO specialist — audits, content creation, technical SEO, daily monitoring",
        "identity": { "name": "Khoa", "emoji": "🔍" },
        "groupChat": {
          "mentionPatterns": ["@khoa", "@seo"]
        },
        "maxConcurrentSessions": 2,
        "sessionTimeout": 60
      }
    ]
  },

  "bindings": [
    {
      "agentId": "lead",
      "match": { "channel": "telegram", "accountId": "default" }
    },
    {
      "agentId": "seo",
      "match": { "channel": "telegram", "accountId": "khoa" }
    }
  ],

  "tools": {
    "sessions": { "visibility": "all" },
    "agentToAgent": {
      "enabled": true,
      "allow": ["lead", "seo"]
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "streaming": "partial",
      "accounts": {
        "default": {
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "dmPolicy": "allowlist",
          "allowFrom": ["${TELEGRAM_ADMIN_USER_ID}", "${TELEGRAM_OPERATOR_USER_IDS}"],
          "groups": {
            "${TELEGRAM_GROUP_CHAT_ID}": {
              "requireMention": false,
              "groupPolicy": "allowlist",
              "allowFrom": ["${TELEGRAM_ADMIN_USER_ID}", "${TELEGRAM_OPERATOR_USER_IDS}"]
            }
          }
        },
        "khoa": {
          "botToken": "${TELEGRAM_KHOA_BOT_TOKEN}",
          "dmPolicy": "allowlist",
          "allowFrom": ["${TELEGRAM_ADMIN_USER_ID}", "${TELEGRAM_OPERATOR_USER_IDS}"],
          "groups": {
            "${TELEGRAM_GROUP_CHAT_ID}": {
              "requireMention": true,
              "groupPolicy": "allowlist",
              "allowFrom": ["${TELEGRAM_ADMIN_USER_ID}", "${TELEGRAM_OPERATOR_USER_IDS}"]
            }
          }
        }
      }
    }
  },

  "plugins": {
    "lossless-claw": {
      "enabled": false,
      "config": {
        "freshTailCount": 32,
        "contextThreshold": 0.75,
        "ignoreSessionPatterns": ["cron-*", "health-*"]
      }
    },
    "self-improving": {
      "enabled": false,
      "config": {
        "hotRulesMax": 50,
        "promotionThreshold": 3,
        "promotionWindow": "7d",
        "demotionThreshold": "30d",
        "weeklyReviewDay": "sunday",
        "weeklyReviewHour": 9
      }
    }
  },

  "sharedKnowledge": {
    "path": "shared-knowledge",
    "gitVersioned": true,
    "files": [
      "company-rules.md",
      "product-catalog.md",
      "lessons-learned.md"
    ]
  },

  "guardrails": {
    "path": "guardrails",
    "approvalRequired": "guardrails/approval-required.yml",
    "rateLimits": "guardrails/rate-limits.yml"
  },

  "scheduling": {
    "dailySEOCheck": {
      "cron": "0 6 * * *",
      "agent": "seo",
      "skill": "wp-daily-check",
      "description": "Daily SEO health check at 6:00 AM"
    },
    "dailyBlogWrite": {
      "cron": "0 8 * * *",
      "agent": "seo",
      "skill": "wp-blog-writer",
      "args": { "action": "auto-write" },
      "description": "Auto-write 1 blog post daily at 8:00 AM ICT"
    },
    "weeklyReport": {
      "cron": "0 8 * * 1",
      "agent": "lead",
      "skill": "task-router",
      "args": { "action": "weekly-report" },
      "description": "Weekly summary report on Monday 8:00 AM"
    }
  },

  "security": {
    "apiKeyScoping": {
      "wordpress": {
        "scope": ["posts", "pages", "media", "categories", "tags"],
        "denyScope": ["users", "settings", "plugins", "themes"]
      },
      "woocommerce": {
        "scope": ["products"],
        "denyScope": ["orders", "customers", "coupons", "settings"]
      }
    },
    "httpsOnly": true,
    "maxRetries": 3,
    "retryBackoff": "exponential"
  },

  "monitoring": {
    "healthCheckInterval": "15m",
    "alertChannel": "telegram",
    "metrics": [
      "container_status",
      "memory_usage",
      "disk_usage",
      "api_errors_per_hour",
      "session_count",
      "backup_age",
      "sqlite_size",
      "last_successful_run"
    ]
  },

  "gateway": {
    "bind": "127.0.0.1:18789",
    "auth": {}
  }
}
